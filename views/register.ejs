<!doctype html>
<html lang="pt" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nexus Chat | Registo</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/static/css/app.css" rel="stylesheet">
</head>
<body class="auth-body">
  <div class="container py-4 py-lg-5">
    <div class="row justify-content-center min-vh-100 align-items-center g-4">
      <div class="col-xl-7">
        <div class="glass-card p-4 p-lg-5">
          <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
            <div>
              <div class="eyebrow">Registo autónomo</div>
              <h2 class="fw-bold mb-1">Criar conta</h2>
              <p class="text-body-secondary mb-0">O próprio utilizador pode registar-se de forma independente e iniciar uma sessão segura.</p>
            </div>
            <button class="btn btn-surface btn-icon" id="themeToggle" type="button" title="Alternar tema">
              <i class="bi bi-moon-stars-fill theme-dark-icon"></i>
              <i class="bi bi-sun-fill theme-light-icon"></i>
            </button>
          </div>
          <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
          <form method="post" action="/register" class="row g-3">
            <div class="col-12">
              <label class="form-label small text-body-secondary">Nome completo</label>
              <input class="form-control form-control-lg" name="fullName" placeholder="Nome completo">
            </div>
            <div class="col-md-6">
              <label class="form-label small text-body-secondary">Utilizador</label>
              <input class="form-control form-control-lg" name="username" placeholder="Utilizador">
            </div>
            <div class="col-md-6">
              <label class="form-label small text-body-secondary">Email</label>
              <input class="form-control form-control-lg" name="email" type="email" placeholder="Email">
            </div>
            <div class="col-12">
              <label class="form-label small text-body-secondary">Palavra-passe</label>
              <input class="form-control form-control-lg" name="password" type="password" placeholder="Palavra-passe">
            </div>
            <div class="col-12 d-grid"><button class="btn btn-primary btn-lg">Registar no Nexus</button></div>
          </form>
          <div class="mt-4 text-center"><a href="/login" class="link-underline link-underline-opacity-0">Já tenho conta</a></div>
        </div>
      </div>
    </div>
  </div>
  <div class="signature-tag">@2026_Psungo_Massunda_Manhica#</div>
  <script src="/static/js/app.js"></script>
</body>
</html>
