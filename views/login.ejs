<!doctype html>
<html lang="pt" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nexus Chat | Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/static/css/app.css" rel="stylesheet">
</head>
<body class="auth-body">
  <div class="container py-4 py-lg-5">
    <div class="row justify-content-center align-items-center min-vh-100 g-4 g-xl-5">
      <div class="col-xl-7">
        <div class="hero-card p-4 p-lg-5 h-100">
          <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
            <span class="badge rounded-pill text-bg-primary-subtle text-primary-emphasis px-3 py-2">Nexus Secure Enterprise Chat</span>
            <button class="btn btn-surface btn-icon" id="themeToggle" type="button" title="Alternar tema">
              <i class="bi bi-moon-stars-fill theme-dark-icon"></i>
              <i class="bi bi-sun-fill theme-light-icon"></i>
            </button>
          </div>
          <div class="hero-grid">
            <div>
              <h1 class="display-6 fw-bold mb-3">Mensagens seguras com identidade digital, controlo administrativo e experiência enterprise.</h1>
              <p class="text-body-secondary mb-4">Plataforma funcional com registo independente, notificações em tempo real, troca de mensagens, envio de imagem segura, PKI simulada, assinatura digital e múltiplos modos criptográficos.</p>
              <div class="row g-3">
                <div class="col-md-6">
                  <div class="mini-feature"><i class="bi bi-shield-lock"></i><span>Criptografia híbrida PGP-style</span></div>
                </div>
                <div class="col-md-6">
                  <div class="mini-feature"><i class="bi bi-bell"></i><span>Alertas instantâneos</span></div>
                </div>
                <div class="col-md-6">
                  <div class="mini-feature"><i class="bi bi-person-plus"></i><span>Cadastro independente</span></div>
                </div>
                <div class="col-md-6">
                  <div class="mini-feature"><i class="bi bi-window-sidebar"></i><span>Design enterprise Bootstrap</span></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-xl-5">
        <div class="glass-card p-4 p-lg-5">
          <div class="mb-4">
            <div class="eyebrow">Acesso seguro</div>
            <h2 class="fw-bold mb-1">Entrar</h2>
            <p class="text-body-secondary mb-0">Use o seu utilizador ou email para aceder ao Nexus.</p>
          </div>
          <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
          <form method="post" action="/login" class="d-grid gap-3">
            <div>
              <label class="form-label small text-body-secondary">Utilizador ou email</label>
              <input class="form-control form-control-lg" name="login" placeholder="Utilizador ou email">
            </div>
            <div>
              <label class="form-label small text-body-secondary">Palavra-passe</label>
              <input class="form-control form-control-lg" type="password" name="password" placeholder="Palavra-passe">
            </div>
            <button class="btn btn-primary btn-lg">Entrar no Nexus</button>
          </form>
          <div class="small text-body-secondary mt-3">Admin inicial: <strong>admin</strong> / <strong>admin123</strong></div>
          <div class="mt-4 text-center"><a href="/register" class="link-underline link-underline-opacity-0">Criar conta</a></div>
        </div>
      </div>
    </div>
  </div>
  <div class="signature-tag">@2026_Psungo_Massunda_Manhica#</div>
  <script src="/static/js/app.js"></script>
</body>
</html>
